# WiFi Configuration
WIFI_SSID=your_wifi_ssid
WIFI_PASS=your_wifi_password

# LLM Provider Configuration
# Supported providers: openrouter, deepseek, gemini, openai_compatible
LLM_PROVIDER=gemini
LLM_API_KEY=your_api_key_here
LLM_MODEL=gemini-2.5-flash
# Optional: Override the base URL. Leave empty to use provider defaults.
LLM_API_BASE_URL=

# Device Configuration
DEVICE_NAME=wireclaw

# Telegram Configuration (Optional)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_COOLDOWN=3

# Discord Configuration (Optional)
DISCORD_TOKEN=
DISCORD_USER_ID=
DISCORD_CHANNEL_ID=

# NATS Configuration (Optional)
NATS_HOST=
NATS_PORT=4222

# System Configuration
TIMEZONE=UTC0
DEBUG=false
